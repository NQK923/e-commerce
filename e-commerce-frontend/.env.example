# Backend API Base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Frontend Base URL
NEXT_PUBLIC_FRONTEND_BASE_URL=http://localhost:3000

# Supabase (for File Uploads)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PRODUCT_BUCKET=product-images
NEXT_PUBLIC_SUPABASE_SELLER_BUCKET=seller-assets
NEXT_PUBLIC_SUPABASE_CHAT_BUCKET=chat-attachments

# Upload Fallback Mode (Use 'placeholder' if Supabase is not configured locally)
NEXT_PUBLIC_UPLOAD_FALLBACK_MODE=placeholder

# OAuth Dev Mode (Use 'enabled' to test OAuth locally without full provider setup)
NEXT_PUBLIC_OAUTH_DEV_MODE=enabled
