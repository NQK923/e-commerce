# Database (PostgreSQL)
DB_URL=jdbc:postgresql://db.xxxxxxxxxxxx.supabase.co:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
DB_CONNECTION_TIMEOUT=60000

# Redis
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# MongoDB (Chat)
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/ecommerce
MONGO_DATABASE=ecommerce

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Mail (Mailpit/SMTP)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false
MAIL_FROM=no-reply@example.com

# Elasticsearch (Optional)
SEARCH_ELASTIC_HOST=http://localhost:9200
SEARCH_ELASTIC_USERNAME=
SEARCH_ELASTIC_PASSWORD=
SEARCH_ELASTIC_INDEX=products
MANAGEMENT_HEALTH_ELASTICSEARCH_ENABLED=false

# Flyway
FLYWAY_ENABLED=true
FLYWAY_CONNECT_RETRIES=5
FLYWAY_CONNECT_RETRIES_INTERVAL=PT5S

# Frontend URLs and CORS
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OAuth2 (Google)
GOOGLE_CLIENT_ID=dummy-client-id
GOOGLE_CLIENT_SECRET=dummy-client-secret
IDENTITY_OAUTH2_DEV_CALLBACK_ENABLED=true

# VNPay
VNPAY_TMN_CODE=demo
VNPAY_HASH_SECRET=demo
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8080/api/payments/vnpay/return
VNPAY_DEV_RETURN_ENABLED=true

# JWT Secret (Added in Phase 2)
JWT_SECRET=yoursecretkeythatisatleast32byteslongforhs256

# Identity Seed Data
IDENTITY_SEED_ADMIN_ENABLED=false
IDENTITY_SEED_ADMIN_EMAIL=admin@example.com
IDENTITY_SEED_ADMIN_PASSWORD=adminpassword
